{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-check.dev/schemas/sampling_plan.schema.json",
  "title": "Sampling plan",
  "description": "A manual Product Preflight plan. It structures perspectives and controls; it does not create a representative sample.",
  "type": "object",
  "required": ["segments", "negative_controls", "kill_criteria", "smallest_real_anchor_required", "claim_limits"],
  "properties": {
    "segments": {
      "type": "object",
      "required": ["fitting", "adjacent", "skeptical", "poor_fit"],
      "properties": {
        "fitting": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "adjacent": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "skeptical": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "poor_fit": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "non_market_control": {
      "type": "object",
      "required": ["segment", "purpose"],
      "properties": {
        "segment": { "type": "string" },
        "purpose": { "type": "string" }
      },
      "additionalProperties": false
    },
    "negative_controls": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "raw_response_policy": {
      "type": "object",
      "properties": {
        "save_before_summary": { "type": "boolean" },
        "preserve_counter_evidence": { "type": "boolean" },
        "separate_evidence_from_interpretation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "prompt_robustness": {
      "type": "object",
      "description": "Prompt robustness can be represented as a file reference and stability rule, not automation.",
      "properties": {
        "plan": { "type": "string" },
        "stable_only_if_repeated_across_variants": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "kill_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "claim_limits": {
      "type": "object",
      "properties": {
        "no_validated_purchase_intent": { "type": "boolean", "const": true },
        "no_representative_claims": { "type": "boolean", "const": true },
        "no_real_user_voices": { "type": "boolean", "const": true },
        "no_demand_prediction": { "type": "boolean", "const": true },
        "no_synthetic_testimonials": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "smallest_real_anchor_required": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
