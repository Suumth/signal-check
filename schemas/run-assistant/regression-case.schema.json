{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Assistant Regression Case",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "category",
    "user_prompt",
    "expected_behavior",
    "must_not",
    "pass_criteria",
    "failure_signals"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "user_prompt": {
      "type": "string"
    },
    "expected_behavior": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_not": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_output_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pass_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
