{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-check.dev/schemas/preflight_report.schema.json",
  "title": "Preflight report",
  "description": "A manual Product Preflight report. It separates synthetic hypotheses from the real-world next test.",
  "type": "object",
  "required": [
    "summary",
    "keep",
    "change",
    "stop",
    "segment_differences",
    "negative_control_readout",
    "kill_criteria_result",
    "claims_not_allowed",
    "smallest_real_anchor"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "description": "Directional interpretation only. Do not claim validation, demand, real user voices, or representative findings."
    },
    "keep": { "type": "array", "items": { "type": "string" } },
    "change": { "type": "array", "items": { "type": "string" } },
    "stop": { "type": "array", "items": { "type": "string" } },
    "segment_differences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "fit_type", "reaction_pattern", "evidence", "counter_evidence", "uncertainty"],
        "properties": {
          "segment_id": { "type": "string" },
          "fit_type": { "enum": ["fitting", "adjacent", "skeptical", "poor_fit", "non_market_control"] },
          "reaction_pattern": { "type": "string" },
          "evidence": { "type": "string" },
          "counter_evidence": { "type": "string" },
          "uncertainty": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "non_market_control_readout": { "type": "string" },
    "negative_control_readout": { "type": "string" },
    "prompt_robustness_readout": {
      "type": "string",
      "description": "Which findings held across variants and which were prompt-sensitive."
    },
    "kill_criteria_result": { "type": "string" },
    "claims_not_allowed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "synthetic_hypotheses": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Hypotheses generated by the preflight. These are not findings from real users unless separately collected."
    },
    "smallest_real_anchor": {
      "type": "object",
      "required": ["target_segment", "concrete_action", "success_evidence", "stop_evidence", "time_box", "what_this_does_not_prove"],
      "properties": {
        "target_segment": { "type": "string" },
        "reachability": { "type": "string" },
        "concrete_action": { "type": "string" },
        "success_evidence": { "type": "string" },
        "stop_evidence": { "type": "string" },
        "time_box": { "type": "string" },
        "what_this_does_not_prove": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
