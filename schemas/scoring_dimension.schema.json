{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-check.dev/schemas/scoring_dimension.schema.json",
  "title": "Scoring dimension",
  "type": "object",
  "required": ["id", "name", "anchors"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "description"],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
